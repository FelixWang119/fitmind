# ============================================
# 环境配置文件 (.env.example)
# 复制此文件为 .env 并根据需要修改配置
# ============================================

# ========== 安全警告 ==========
# 1. 永远不要将真实的API密钥和密码提交到版本控制
# 2. 生产环境必须使用强密码和随机密钥
# 3. 定期轮换敏感密钥

# ========== AI服务配置 ==========
# 通义千问API密钥 (从阿里云控制台获取)
QWEN_API_KEY=your_qwen_api_key_here_do_not_commit_real_key

# ========== 后端安全配置 ==========
# 用于JWT令牌签名和加密的密钥 (生产环境必须使用强随机字符串)
# 生成命令: openssl rand -hex 32
SECRET_KEY=dev_secret_key_change_in_production_use_openssl_rand_hex_32

# JWT令牌过期时间 (秒)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 密码哈希算法配置
BCRYPT_ROUNDS=12

# ========== 数据库配置 ==========
# 开发环境使用Docker Compose中的默认值
# 生产环境需要配置真实的数据库连接
DATABASE_URL=postgresql://weight_ai_user:weight_ai_password@localhost:5432/weight_ai_db

# 数据库连接池配置
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# ========== 环境配置 ==========
# 可选值: development, testing, staging, production
ENVIRONMENT=development

# 调试模式 (仅开发环境启用)
DEBUG=true

# CORS配置 (生产环境需要限制域名)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ========== 前端配置 ==========
# Vite开发服务器配置
VITE_API_URL=http://localhost:8000
VITE_ENVIRONMENT=development

# ========== 日志配置 ==========
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=/var/log/weight_ai/backend.log

# ========== 速率限制配置 ==========
# API速率限制 (请求/分钟)
RATE_LIMIT_PER_MINUTE=60

# ========== 监控配置 ==========
# Sentry错误监控 (可选)
SENTRY_DSN=

# ========== 缓存配置 ==========
# Redis连接URL (开发环境使用Docker Compose中的Redis)
REDIS_URL=redis://localhost:6379/0

# ========== 文件存储配置 ==========
# 上传文件大小限制 (字节)
MAX_UPLOAD_SIZE=10485760  # 10MB

# ========== 邮件配置 (可选) ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@weightai.com