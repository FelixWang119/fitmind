                  <div>
                    <p className="text-xl font-bold text-blue-500">{data.chart_data?.nutrition_breakdown.protein || 150}g</p>
                    <p className="text-xs sm:text-sm text-gray-500">蛋白</p>
                  </div>
                  <div>
                    <p className="text-xl font-bold text-yellow-500">{data.chart_data?.nutrition_breakdown.fat || 78}g</p>
                    <p className="text-xs sm:text-sm text-gray-500">脂肪</p>
                  </div>
                </div>
              </div>
              
              {/* 情绪状态 */}
                <div className="bg-white rounded-xl shadow p-4 sm:p-6">
              <h3 className="text-base sm:text-lg font-semibold text-gray-800 mb-3 sm:mb-4 flex items-center">
                  <Heart className="h-5 w-5 mr-2 text-rose-600" /> 
                  情绪健康
                </h3>
                
                <div className="space-y-4">
                  <div>
                    <div className="flex justify-between mb-1">
                      <span className="text-sm font-medium text-gray-700">压力水平</span>
                      <span className="text-sm font-medium text-gray-700">{data.emotional_data?.stress_level || 6}/10</span>
                    </div>
                    <div className="w-full bg-gray-200 rounded-full h-2.5">
                      <div 
                        className="bg-red-600 h-2.5 rounded-full" 
                        style={{ width: `${(data.emotional_data?.stress_level || 6) * 10}%` }}
                      ></div>
                    </div>
                  </div>
                  
                  <div>
                    <div className="flex justify-between mb-1">
                      <span className="text-sm font-medium text-gray-700">心情指数</span>
                      <span className="text-sm font-medium text-gray-700">{data.emotional_data?.mood_score || 8}/10</span>
                    </div>
                    <div className="w-full bg-gray-200 rounded-full h-2.5">
                      <div 
                        className="bg-green-500 h-2.5 rounded-full" 
                        style={{ width: `${(data.emotional_data?.mood_score || 8) * 10}%` }}
                      ></div>
