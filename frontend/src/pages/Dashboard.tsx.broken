            />
            <QuickActionButton
              icon={CheckCircle}
              label="打卡习惯"
              onClick={() => alert('习惯打卡功能即将上线！')}
              color="cyan"
            />
          </div>
        </div>

        <div className="grid grid-cols-1 lg:grid-cols-3 gap-6 sm:gap-8">
          {/* 左侧主要内容 */}
          <div className="lg:col-span-2 space-y-6 sm:space-y-8">
            <div className="bg-white rounded-xl shadow p-4 sm:p-6">
              <div className="flex justify-between items-center mb-6">
                <h2 className="text-lg sm:text-xl font-bold text-gray-800">体重趋势</h2>
                <button 
                  className="flex items-center text-sm text-primary-600"
                >
                  <Eye className="h-4 w-4 mr-1" />
                  显示数值
                </button>
              </div>
              
              <div className="h-48 sm:h-64 md:h-80">
                <Line 
                  data={{
                    labels: data.chart_data?.weight_trend.dates || ['1月', '2月', '3月', '4月', '5月', '6月', '7月'],
                    datasets: [{
                      label: '体重 (kg)',
                      data: data.chart_data?.weight_trend.weights || [75.2, 74.8, 74.5, 74.2, 73.8, 73.2, 72.8],
                      borderColor: '#4F46E5',
                      backgroundColor: 'rgba(79, 70, 229, 0.1)',
                      tension: 0.4,
                      fill: true
                    }]
                  }}
                    options={{
                      responsive: true,
                      maintainAspectRatio: false,
                      interaction: {
                        intersect: false,
                        mode: 'index'
                      },
                      plugins: {
                        legend: {
                          position: 'top',
                        },
                        tooltip: {
                          enabled: true 
                        }
                      },
                      scales: {
                        y: {
                          beginAtZero: false
                        }
                      }
