import { useEffect, useState } from 'react';
import {
  Activity,
  Target,
  Flame,
  Droplets,
  TrendingDown,
  Calendar,
  ChevronRight,
  Heart,
  TrendingUp,
  Eye,
  EyeOff,
  Award,
  Utensils,
  MessageSquare,
  CheckCircle
} from 'lucide-react';
import { Bar, Line, Doughnut } from 'react-chartjs-2';
import { 
  Chart as ChartJS,
  CategoryScale,
  LinearScale,
  PointElement,
  LineElement,
  BarElement,
  ArcElement,
  Title,
  Tooltip,
  Legend
} from 'chart.js';
import { api } from '../api/client';

ChartJS.register(
  CategoryScale,
  LinearScale,
  PointElement,
  LineElement,
  BarElement,
  ArcElement,
  Title,
  Tooltip,
  Legend
);

interface DashboardData {
  greeting?: string;
  daily_tip?: {
    title: string;
    content: string;
  };
  progress_summary?: {
    weight_progress: number;
    habit_completion: number;
    current_level: number;
    total_points: number;
  };
  next_steps?: any[];
  overview?: {
    total_weight_loss: number;
    bmi: number;
    weekly_average: number;
    days_tracked: number;
    active_habits: number;
    streak_days: number;
    total_points: number;
  };
  quick_stats?: {
    today_calories: number;
    daily_step_count: number;
    water_intake: number;
    sleep_hours: number;
  };
  chart_data?: {
    weight_trend: {
      dates: string[];
      weights: number[];
    };
    nutrition_breakdown: {
      carbs: number;
      protein: number;
      fat: number;
    };
  };
  emotional_data?: {
    stress_level: number;
    mood_score: number;
    week_overview: Array<{
      day: string;
      mood: number;
      stress: number;
    }>;
  };
  badges?: Array<{
    id: number;
    name: string;
    description: string;
    earned: boolean;
    icon: string;
  }>;
}

interface StatCardProps {
  icon: React.ElementType;
  label: string;
  value: string;
  color: 'blue' | 'green' | 'purple' | 'orange';
}

function StatCard({ icon: Icon, label, value, color }: StatCardProps) {
  const colorClasses = {
    blue: 'bg-blue-50 text-blue-600',
    green: 'bg-green-50 text-green-600',
    purple: 'bg-purple-50 text-purple-600',
    orange: 'bg-orange-50 text-orange-600',
  };

  return (
    <div className="bg-white rounded-2xl shadow-sm border border-gray-200 p-4">
      <div className={`w-10 h-10 rounded-xl ${colorClasses[color]} flex items-center justify-center mb-3`}>
        <Icon className="w-5 h-5" />
      </div>
      <p className="text-sm text-gray-500 mb-1">{label}</p>
      <p className="text-xl font-bold text-gray-900">{value}</p>
    </div>
  );
}

interface QuickActionButtonProps {
  icon: React.ElementType;
  label: string;
  onClick: () => void;
  color: string;
}

function QuickActionButton({ icon: Icon, label, onClick, color }: QuickActionButtonProps) {
  const colorMap: Record<string, string> = {
    blue: 'bg-blue-50 hover:bg-blue-100 text-blue-600',
    green: 'bg-green-50 hover:bg-green-100 text-green-600',
    cyan: 'bg-cyan-50 hover:bg-cyan-100 text-cyan-600',
    orange: 'bg-orange-50 hover:bg-orange-100 text-orange-600',
  };

  return (
    <button
      onClick={onClick}
      className={`flex flex-col items-center justify-center p-4 rounded-2xl transition-colors ${colorMap[color] || colorMap.blue}`}
    >
      <Icon className="w-6 h-6 mb-2" />
      <span className="text-sm font-medium">{label}</span>
    </button>
  );
}

export default function Dashboard() {
  const [data, setData] = useState<DashboardData>({});
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState('');

  useEffect(() => {
    loadDashboardData();
  }, []);

  const loadDashboardData = async () => {
    try {
      setLoading(true);
      // 获取仪表板概览数据
      const dashboardData = await api.getDashboardOverview();
      // 获取快速统计数据
      const quickStatsData = await api.getQuickStats();
      // 获取AI建议数据
      const aiSuggestionsData = await api.getAiSuggestions();
      // 获取趋势数据
      const trendsData = await api.getTrends();
      
      // 合并数据，同时适配图表数据的格式
      setData({
        ...dashboardData,
        quickStats: quickStatsData,
        ai_suggestions: aiSuggestionsData?.suggestions || [],
        trends: trendsData,
        // Map trend data to the expected chart_data structure
        chart_data: {
          weight_trend: {
            dates: trendsData?.weight_trend?.data?.map((item: any) => item.date.split('-')[1] + '-' + item.date.split('-')[2]) || ['周一', '周二', '周三', '周四', '周五', '周六', '周日'], // Simple MM-DD format
            weights: trendsData?.weight_trend?.data?.map((item: any) => item.weight_kg) || [72.3, 72.1, 71.9, 71.8, 71.6, 71.5, 71.4]
          },
          nutrition_breakdown: {
            carbs: dashboardData?.chart_data?.nutrition_breakdown?.carbs || 230,
            protein: dashboardData?.chart_data?.nutrition_breakdown?.protein || 150,
            fat: dashboardData?.chart_data?.nutrition_breakdown?.fat || 78
          }
        }
      });
    } catch (err) {
      setError('加载数据失败');
      console.error(err);
      
      // 如果API调用失败，使用模拟数据
      setData({
        greeting: '欢迎回来，测试用户！',
        daily_tip: {
          title: '今日运动建议',
          content: '今天是健身的好时间！尝试安排30分钟的有氧运动，比如快走或骑自行车。您的水分摄入略低，记得多喝水保持身体水分平衡。'
        },
        progress_summary: {
          weight_progress: 5.2,
          habit_completion: 75,
          current_level: 5,
          total_points: 1250
        },
        overview: {
          total_weight_loss: 5.2,
          bmi: 22.4,
          weekly_average: 0.8,
          days_tracked: 24,
          active_habits: 8,
          streak_days: 12,
          total_points: 1250
        },
        quick_stats: {
          today_calories: 1850,
          daily_step_count: 8542,
          water_intake: 1800,
          sleep_hours: 7.5
        },
        chart_data: {
          weight_trend: {
            dates: ['周一', '周二', '周三', '周四', '周五', '周六', '周日'],
            weights: [72.3, 72.1, 71.9, 71.8, 71.6, 71.5, 71.4]
          },
          nutrition_breakdown: {
            carbs: 230,
            protein: 150,
            fat: 78
          }
        },
        emotional_data: {
          stress_level: 6,
          mood_score: 8,
          week_overview: [
            { day: '周一', mood: 8, stress: 5 },
            { day: '周二', mood: 7, stress: 6 },
            { day: '周三', mood: 9, stress: 4 },
            { day: '周四', mood: 6, stress: 7 },
            { day: '周五', mood: 8, stress: 5 },
            { day: '周六', mood: 9, stress: 3 },
            { day: '周日', mood: 8, stress: 4 }
          ]
        },
        badges: [
          { id: 1, name: '早起鸟', description: '连续早起一周', earned: true, icon: '🌅' },
          { id: 2, name: '水水水', description: '每日八杯水', earned: true, icon: '💧' },
          { id: 3, name: '夜宵戒断', description: '21天不进夜宵', earned: false, icon: '🌙' },
          { id: 4, name: '蔬果达人', description: '每日蔬果5份', earned: true, icon: '🥗' },
          { id: 5, name: '连续记录', description: '健康记录不间断', earned: true, icon: '📝' },
          { id: 6, name: '突破瓶颈', description: '突破体重平台期', earned: false, icon: '📈' }
        ]
      });
    } finally {
      setLoading(false);
    }
  };

  if (loading) {
    return (
      <div className="min-h-screen flex items-center justify-center bg-gray-50 p-4">
        <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600"></div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gray-50 pb-12">
      {/* 头部 */}
      <header className="bg-gradient-to-r from-primary-600 to-secondary-600 text-white p-6 shadow-md">
        <div className="max-w-7xl mx-auto">
          <div className="flex justify-between items-center">
            <div>
              <h1 className="text-2xl font-bold">{data.greeting || '欢迎回来！'}</h1>
              <p className="text-primary-100 mt-1">今日健康进度概览</p>
            </div>
            <div className="flex items-center space-x-4">
              <div className="text-right">
                <p className="font-semibold">{new Date().toLocaleDateString('zh-CN', { weekday: 'long' })}</p>
                <p className="text-sm opacity-80">{new Date().toLocaleDateString('zh-CN')}</p>
              </div>
            </div>
          </div>
        </div>
      </header>

      {/* 主内容区 */}
      <main className="max-w-7xl mx-auto p-4 sm:p-6">
        {/* 快速统计 第一行*/}
        <div className="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6 mb-6 sm:mb-8">
          <div className="bg-white rounded-xl shadow p-6 flex items-center">
            <div className="bg-green-100 p-3 rounded-full mr-4">
              <TrendingUp className="h-6 w-6 text-green-600" />
            </div>
            <div>
              <p className="text-gray-500 text-sm">本周减重</p>
              <p className="text-2xl font-bold text-gray-800">{data.overview?.weekly_average ? data.overview.weekly_average.toFixed(2) : 0.8} kg</p>
            </div>
          </div>
          
          <div className="bg-white rounded-xl shadow p-6 flex items-center">
            <div className="bg-blue-100 p-3 rounded-full mr-4">
              <Target className="h-6 w-6 text-blue-600" />
            </div>
            <div>
              <p className="text-gray-500 text-sm">当前BMI</p>
              <p className="text-2xl font-bold text-gray-800">{data.overview?.bmi || 22.4}</p>
            </div>
          </div>
          
          <div className="bg-white rounded-xl shadow p-6 flex items-center">
            <div className="bg-purple-100 p-3 rounded-full mr-4">
