          {/* 右侧边栏 */}
          <div className="space-y-6 sm:space-y-8">
            {/* 今日数据 */}
            <div className="bg-white rounded-xl shadow p-4 sm:p-6">
              <h3 className="text-base sm:text-lg font-semibold text-gray-800 mb-3 sm:mb-4">今日快照</h3>
              
              <div className="space-y-4">
                <div className="flex justify-between items-center pb-3 border-b">
                  <span className="text-gray-600">摄入卡路里</span>
                  <span className="font-semibold">{data.quick_stats?.today_calories || 1850} kcal</span>
                </div>
                
                <div className="flex justify-between items-center pb-3 border-b">
