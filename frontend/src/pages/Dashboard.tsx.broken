            </div>
            
            {/* Daily Tips and AI Suggestions */}
            {(data.daily_tip || (data.ai_suggestions && data.ai_suggestions.length > 0)) && (
              <div className="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl p-4 sm:p-6 border border-blue-100">
                <div className="flex justify-between items-start mb-2">
                  <div>
                <h3 className="text-base sm:text-lg font-semibold text-gray-800">AI健康建议</h3>
                    <p className="text-gray-600 text-xs sm:text-sm mt-1">
                      基于您的最新数据，AI为您定制的健康建议
                    </p>
                  </div>
                </div>
                
                {/* Display daily tip if available */}
                {data.daily_tip && (
                  <div className="mb-4">
                    <div className="bg-white p-4 rounded-lg mt-4">
                      <p className="text-gray-800 text-sm">
                        {data.daily_tip.content ||
                          "今天是健身的好时间！尝试30分钟有氧运动，如快走或自行车。您今天的水分摄入略低，记得补水以维持新陈代谢。"}
                      </p>
                    </div>
                    
                    <div className="mt-4 flex space-x-2">
                      <button 
                        onClick={() => alert('已标记为已完成')}
                        className="flex-1 bg-green-100 hover:bg-green-200 text-green-700 px-2 py-1 sm:px-3 sm:py-2 rounded-lg text-xs sm:text-sm font-medium transition-colors"
                      >
                        ✓ 标记完成
                      </button>
                      <button 
                        onClick={() => alert('已收藏此建议')}
                        className="flex-1 bg-blue-100 hover:bg-blue-200 text-blue-700 px-2 py-1 sm:px-3 sm:py-2 rounded-lg text-xs sm:text-sm font-medium transition-colors"
                      >
                        ♡ 收藏
                      </button>
                    </div>
                  </div>
                )}
                
                {/* Display additional AI suggestions if available */}
                {data.ai_suggestions && data.ai_suggestions.length > 0 && (
                  <div className="space-y-3">
                    {data.ai_suggestions.map((suggestion: any, idx: number) => (
                      <div key={`suggestion-${idx}`} className="bg-white p-3 rounded-lg">
                        <p className="text-gray-800 text-sm">{suggestion.title || suggestion.content || suggestion.advice || `推荐建议 ${idx + 1}`}</p>
                        
                        <div className="mt-2 flex space-x-2">
                          <button 
                            onClick={() => alert(`已标记建议完成: ${idx + 1}`)}
                            className="flex-1 bg-green-100 hover:bg-green-200 text-green-700 px-2 py-1 rounded-lg text-xs font-medium transition-colors"
                          >
                            ✓ 标记
                          </button>
                          <button 
                            onClick={() => alert(`已收藏建议: ${idx + 1}`)}
                            className="flex-1 bg-blue-100 hover:bg-blue-200 text-blue-700 px-2 py-1 rounded-lg text-xs font-medium transition-colors"
                          >
                            ♡ 收藏  
                          </button>
                          <button 
                            onClick={() => alert(`执行建议: ${idx + 1}`)}
                            className="flex-1 bg-purple-100 hover:bg-purple-200 text-purple-700 px-2 py-1 rounded-lg text-xs font-medium transition-colors"
                          >
                            一键执行
                          </button>
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            )}
            
              <h3 className="text-base sm:text-lg font-semibold text-gray-800 flex items-center">
                <Award className="h-4 sm:h-5 w-4 sm:w-5 mr-2 text-yellow-600" /> 
                我的徽章
              </h3>
              
              <div className="grid grid-cols-2 sm:grid-cols-3 gap-2 sm:gap-3">
                {(data.badges || []).slice(0, 6).map((badge: any, index: number) => (
                  <div 
                    key={badge.id || index} 
                    className={`flex flex-col items-center p-2 rounded-lg ${
                      badge.earned ? 'bg-yellow-50 border border-yellow-200' : 'bg-gray-50 opacity-60'
                    }`}
                  >
                    <div className={`w-10 h-10 rounded-full flex items-center justify-center ${
                      badge.earned ? 'bg-yellow-100' : 'bg-gray-200'
                    }`}>
                      <span className="text-lg"> {(badge.icon && typeof badge.icon === 'string') ? badge.icon : '🏆'}</span>
                    </div>
                    <span className="text-xs mt-1 text-center">{badge.name || `徽章 ${index + 1}`}</span>
                  </div>
                ))}
                {((data.badges || []).length === 0) && [0,1,2,3,4,5].map((_, index) => (
                  <div 
                    key={`empty-${index}`} 
                    className="flex flex-col items-center p-2 rounded-lg bg-gray-50 opacity-60"
                  >
                    <div className="w-10 h-10 rounded-full flex items-center justify-center bg-gray-200">
                      <span className="text-lg"> {'🏆'}</span>
                    </div>
                    <span className="text-xs mt-1 text-center">{["早起鸟", "水水水", "夜宵戒断", "蔬果达人", "连续记录", "突破瓶颈"][index]}</span>
                  </div>
                ))}
              </div>
              
              <button className="mt-4 w-full text-center text-sm text-primary-600">
                查看全部
              </button>
            </div>
            
            {/* Quick Actions */}
            <div className="space-y-3">
              <h3 className="text-lg font-semibold text-gray-800 mb-2">快捷操作</h3>
              <div className="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4">
                <button
                  className="flex flex-col items-center justify-center p-2 sm:p-3 bg-blue-50 hover:bg-blue-100 text-blue-600 rounded-xl transition-colors"
                >
                  <Activity className="w-5 h-5 mb-1" />
                  <span className="text-xs font-medium">记录体重</span>
                </button>
                <button
                  className="flex flex-col items-center justify-center p-2 sm:p-3 bg-green-50 hover:bg-green-100 text-green-600 rounded-xl transition-colors"
                >
                  <Calendar className="w-5 h-5 mb-1" />
                  <span className="text-xs font-medium">完成习惯</span>
                </button>
                <button
                  className="flex flex-col items-center justify-center p-2 sm:p-3 bg-cyan-50 hover:bg-cyan-100 text-cyan-600 rounded-xl transition-colors"
                >
                  <Droplets className="w-5 h-5 mb-1" />
                  <span className="text-xs font-medium">记录饮食</span>
                </button>
                <button
                  className="flex flex-col items-center justify-center p-2 sm:p-3 bg-orange-50 hover:bg-orange-100 text-orange-600 rounded-xl transition-colors"
                >
                  <Flame className="w-5 h-5 mb-1" />
                  <span className="text-xs font-medium">情感签到</span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  );
}