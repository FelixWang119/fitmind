# ============================================
# 生产环境配置文件 (.env.production.example)
# 复制此文件为 .env.production 并配置所有值
# ============================================

# ========== 安全警告 ==========
# 生产环境必须配置所有值，不能使用默认值
# 所有密钥必须使用强随机字符串

# ========== AI服务配置 ==========
QWEN_API_KEY=REPLACE_WITH_REAL_PRODUCTION_API_KEY

# ========== 后端安全配置 ==========
# 使用命令生成: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_STRING_FROM_OPENSSL_RAND_HEX_32

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
BCRYPT_ROUNDS=14

# ========== 数据库配置 ==========
# 生产数据库连接 (使用环境变量或密钥管理服务)
DATABASE_URL=postgresql://username:password@production-db-host:5432/weight_ai_db_production

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=1800

# ========== 环境配置 ==========
ENVIRONMENT=production
DEBUG=false

# 生产环境CORS配置 (限制为前端域名)
CORS_ORIGINS=https://your-frontend-domain.com

# ========== 前端配置 ==========
VITE_API_URL=https://your-backend-domain.com
VITE_ENVIRONMENT=production

# ========== 日志配置 ==========
LOG_LEVEL=WARNING
LOG_FILE=/var/log/weight_ai/production.log

# ========== 速率限制配置 ==========
RATE_LIMIT_PER_MINUTE=30

# ========== 监控配置 ==========
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# ========== 缓存配置 ==========
REDIS_URL=redis://production-redis-host:6379/0

# ========== 文件存储配置 ==========
MAX_UPLOAD_SIZE=5242880  # 5MB

# ========== 邮件配置 ==========
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASSWORD=your-email-password
EMAIL_FROM=noreply@your-domain.com