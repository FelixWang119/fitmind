#!/bin/bash
# 服务管理脚本 - 启动/停止 前端、后端和数据库服务

set -e

# 配置
FRONTEND_DIR="$(cd "$(dirname "$0")/../frontend" && pwd)"
BACKEND_DIR="$(cd "$(dirname "$0")/../backend" && pwd)"
DATA_DIR="/Users/felix/pgsql_data"
LOG_DIR="$(cd "$(dirname "$0")/../logs" && pwd)"
FRONTEND_PORT=3000
BACKEND_PORT=8000

# 颜色
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# 日志
mkdir -p "$LOG_DIR"
FRONTEND_LOG="$LOG_DIR/frontend.log"
BACKEND_LOG="$LOG_DIR/backend.log"
POSTGRES_LOG="/tmp/postgres.log"

# ==================== 帮助 ====================
show_usage() {
    echo "用法：$0 <服务> <操作>"
    echo ""
    echo "服务:"
    echo "  all       - 所有服务（前端 + 后端 + 数据库）"
    echo "  frontend  - 前端服务"
    echo "  backend   - 后端服务"
    echo "  postgres  - PostgreSQL 数据库"
    echo ""
    echo "操作:"
    echo "  start     - 启动服务"
    echo "  stop      - 停止服务"
    echo "  restart   - 重启服务"
    echo "  status    - 查看状态"
    echo ""
    echo "示例:"
    echo "  $0 all start      # 启动所有服务"
    echo "  $0 frontend start # 启动前端"
    echo "  $0 backend stop   # 停止后端"
    echo "  $0 all status     # 查看所有服务状态"
    echo ""
}

# ==================== PostgreSQL 管理 ====================
postgres_start() {
    echo -e "${YELLOW}🐘 启动 PostgreSQL...${NC}"
    
    if pg_isready -h 127.0.0.1 -p 5432 &>/dev/null; then
        echo -e "${GREEN}✅ PostgreSQL 已经在运行${NC}"
        return 0
    fi
    
    if [ ! -d "$DATA_DIR" ]; then
        echo -e "${RED}❌ 数据目录不存在：$DATA_DIR${NC}"
        return 1
    fi
    
    /opt/local/lib/postgresql16/bin/pg_ctl -D "$DATA_DIR" -l "$POSTGRES_LOG" start &>/dev/null
    sleep 2
    
    if pg_isready -h 127.0.0.1 -p 5432 &>/dev/null; then
        echo -e "${GREEN}✅ PostgreSQL 启动成功${NC}"
        return 0
    else
        echo -e "${RED}❌ PostgreSQL 启动失败${NC}"
        return 1
    fi
}

postgres_stop() {
    echo -e "${YELLOW}🐘 停止 PostgreSQL...${NC}"
    
    if ! pg_isready -h 127.0.0.1 -p 5432 &>/dev/null; then
        echo -e "${GREEN}✅ PostgreSQL 已经停止${NC}"
        return 0
    fi
    
    /opt/local/lib/postgresql16/bin/pg_ctl -D "$DATA_DIR" stop &>/dev/null
    sleep 2
    
    if ! pg_isready -h 127.0.0.1 -p 5432 &>/dev/null; then
        echo -e "${GREEN}✅ PostgreSQL 已停止${NC}"
        return 0
    else
        echo -e "${RED}❌ PostgreSQL 停止失败${NC}"
        return 1
    fi
}

postgres_status() {
    echo -e "PostgreSQL:"
    if pg_isready -h 127.0.0.1 -p 5432 &>/dev/null; then
        echo -e "  ${GREEN}✅ 运行中${NC} (127.0.0.1:5432)"
    else
        echo -e "  ${RED}❌ 已停止${NC}"
    fi
}

# ==================== 后端服务管理 ====================
backend_start() {
    echo -e "${YELLOW}🚀 启动后端服务...${NC}"
    
    # 检查是否已有进程
    if lsof -i :$BACKEND_PORT &>/dev/null; then
        echo -e "${GREEN}✅ 后端服务已经在运行 (端口 $BACKEND_PORT)${NC}"
        return 0
    fi
    
    cd "$BACKEND_DIR"
    
    # 启动后端（后台运行）
    nohup uvicorn app.main:app --host 0.0.0.0 --port $BACKEND_PORT --reload > "$BACKEND_LOG" 2>&1 &
    BACKEND_PID=$!
    echo $BACKEND_PID > "$LOG_DIR/backend.pid"
    
    sleep 3
    
    if lsof -i :$BACKEND_PORT &>/dev/null; then
        echo -e "${GREEN}✅ 后端服务启动成功${NC} (PID: $BACKEND_PID)"
        echo -e "  日志：$BACKEND_LOG"
        echo -e "  API:  http://localhost:$BACKEND_PORT"
        echo -e "  文档：http://localhost:$BACKEND_PORT/docs"
        return 0
    else
        echo -e "${RED}❌ 后端服务启动失败${NC}"
        echo -e "查看日志：tail -30 $BACKEND_LOG"
        return 1
    fi
}

backend_stop() {
    echo -e "${YELLOW}🛑 停止后端服务...${NC}"
    
    # 尝试从 PID 文件停止
    if [ -f "$LOG_DIR/backend.pid" ]; then
        BACKEND_PID=$(cat "$LOG_DIR/backend.pid")
        if ps -p $BACKEND_PID &>/dev/null; then
            kill $BACKEND_PID 2>/dev/null
            rm -f "$LOG_DIR/backend.pid"
            sleep 2
            echo -e "${GREEN}✅ 后端服务已停止${NC}"
            return 0
        fi
    fi
    
    # 通过端口查找进程
    BACKEND_PID=$(lsof -t -i :$BACKEND_PORT 2>/dev/null)
    if [ -n "$BACKEND_PID" ]; then
        kill $BACKEND_PID 2>/dev/null
        sleep 2
        echo -e "${GREEN}✅ 后端服务已停止${NC}"
        return 0
    fi
    
    echo -e "${GREEN}✅ 后端服务已经停止${NC}"
    return 0
}

backend_status() {
    echo -e "后端服务:"
    if lsof -i :$BACKEND_PORT &>/dev/null; then
        PID=$(lsof -t -i :$BACKEND_PORT)
        echo -e "  ${GREEN}✅ 运行中${NC} (端口 $BACKEND_PORT, PID: $PID)"
    else
        echo -e "  ${RED}❌ 已停止${NC}"
    fi
}

# ==================== 前端服务管理 ====================
frontend_start() {
    echo -e "${YELLOW}🎨 启动前端服务...${NC}"
    
    # 检查是否已有进程
    if lsof -i :$FRONTEND_PORT &>/dev/null; then
        echo -e "${GREEN}✅ 前端服务已经在运行 (端口 $FRONTEND_PORT)${NC}"
        return 0
    fi
    
    # 检查 node_modules
    if [ ! -d "$FRONTEND_DIR/node_modules" ]; then
        echo -e "${RED}❌ 未找到 node_modules，请先运行：cd frontend && npm install${NC}"
        return 1
    fi
    
    cd "$FRONTEND_DIR"
    
    # 启动前端（后台运行）
    nohup npm run dev > "$FRONTEND_LOG" 2>&1 &
    FRONTEND_PID=$!
    echo $FRONTEND_PID > "$LOG_DIR/frontend.pid"
    
    sleep 5
    
    if lsof -i :$FRONTEND_PORT &>/dev/null; then
        echo -e "${GREEN}✅ 前端服务启动成功${NC} (PID: $FRONTEND_PID)"
        echo -e "  日志：$FRONTEND_LOG"
        echo -e "  地址：http://localhost:$FRONTEND_PORT"
        return 0
    else
        echo -e "${RED}❌ 前端服务启动失败${NC}"
        echo -e "查看日志：tail -30 $FRONTEND_LOG"
        return 1
    fi
}

frontend_stop() {
    echo -e "${YELLOW}🛑 停止前端服务...${NC}"
    
    # 尝试从 PID 文件停止
    if [ -f "$LOG_DIR/frontend.pid" ]; then
        FRONTEND_PID=$(cat "$LOG_DIR/frontend.pid")
        if ps -p $FRONTEND_PID &>/dev/null; then
            kill $FRONTEND_PID 2>/dev/null
            rm -f "$LOG_DIR/frontend.pid"
            sleep 2
            echo -e "${GREEN}✅ 前端服务已停止${NC}"
            return 0
        fi
    fi
    
    # 通过端口查找进程
    FRONTEND_PID=$(lsof -t -i :$FRONTEND_PORT 2>/dev/null)
    if [ -n "$FRONTEND_PID" ]; then
        kill $FRONTEND_PID 2>/dev/null
        sleep 2
        echo -e "${GREEN}✅ 前端服务已停止${NC}"
        return 0
    fi
    
    echo -e "${GREEN}✅ 前端服务已经停止${NC}"
    return 0
}

frontend_status() {
    echo -e "前端服务:"
    if lsof -i :$FRONTEND_PORT &>/dev/null; then
        PID=$(lsof -t -i :$FRONTEND_PORT)
        echo -e "  ${GREEN}✅ 运行中${NC} (端口 $FRONTEND_PORT, PID: $PID)"
    else
        echo -e "  ${RED}❌ 已停止${NC}"
    fi
}

# ==================== 主程序 ====================
if [ $# -lt 2 ]; then
    show_usage
    exit 1
fi

SERVICE=$1
ACTION=$2

case "$ACTION" in
    start)
        case "$SERVICE" in
            all)
                postgres_start
                backend_start
                frontend_start
                ;;
            frontend)
                frontend_start
                ;;
            backend)
                backend_start
                ;;
            postgres)
                postgres_start
                ;;
            *)
                echo -e "${RED}❌ 未知服务：$SERVICE${NC}"
                show_usage
                exit 1
                ;;
        esac
        ;;
    
    stop)
        case "$SERVICE" in
            all)
                frontend_stop
                backend_stop
                postgres_stop
                ;;
            frontend)
                frontend_stop
                ;;
            backend)
                backend_stop
                ;;
            postgres)
                postgres_stop
                ;;
            *)
                echo -e "${RED}❌ 未知服务：$SERVICE${NC}"
                show_usage
                exit 1
                ;;
        esac
        ;;
    
    restart)
        case "$SERVICE" in
            all)
                echo -e "${YELLOW}🔄 重启所有服务...${NC}"
                frontend_stop
                backend_stop
                postgres_stop
                sleep 1
                postgres_start
                backend_start
                frontend_start
                ;;
            frontend)
                frontend_stop
                sleep 1
                frontend_start
                ;;
            backend)
                backend_stop
                sleep 1
                backend_start
                ;;
            postgres)
                postgres_stop
                sleep 1
                postgres_start
                ;;
            *)
                echo -e "${RED}❌ 未知服务：$SERVICE${NC}"
                show_usage
                exit 1
                ;;
        esac
        ;;
    
    status)
        echo "服务状态"
        echo "========"
        postgres_status
        backend_status
        frontend_status
        ;;
    
    *)
        echo -e "${RED}❌ 未知操作：$ACTION${NC}"
        show_usage
        exit 1
        ;;
esac

echo ""
